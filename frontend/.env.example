# Copy to .env.development or set in Vercel → Environment Variables
# Local: use /api so Vite proxies to the backend (vite.config.js)
VITE_API_BASE_URL=/api

# Production: hosted API
 VITE_API_BASE_URL=https://rashibazar.onrender.com/api

# Optional: request timeout in ms (default 60000)
 VITE_API_TIMEOUT_MS=60000
